# ---- App ----
# The CMS backend now lives inside this Next.js app at /api (no separate server).
NEXT_PUBLIC_CMS_API_URL=/api

# ---- Environment ----
NODE_ENV=development

# ---- Database ----
MONGO_URI=mongodb://127.0.0.1:27017/moniket_cms
MONGO_DB_NAME=moniket_cms
# Override DNS for mongodb+srv:// (Atlas) lookups if your network blocks it.
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# ---- Seed admin (used by `npm run seed`) ----
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@moniket.tech
SEED_ADMIN_PASSWORD=changeme123

# ---- Cloudinary (Media Library) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=moniket
